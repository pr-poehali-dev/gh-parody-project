{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Upload small file",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "upload",
        "filename": "hello.txt",
        "content_type": "text/plain",
        "content_base64": "SGVsbG8gR2l0QnJhdCE="
      },
      "expectedStatus": 200,
      "expectedBody": { "url": "string", "filename": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Reject empty upload",
      "method": "POST",
      "path": "/",
      "body": { "action": "upload", "filename": "x.txt" },
      "expectedStatus": 400
    }
  ]
}